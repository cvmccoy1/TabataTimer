<Window x:Class="TabataTimer.EditSequenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TabataTimer.ViewModels"
        xmlns:conv="clr-namespace:TabataTimer.Converters"
        Title="Sequence Editor"
        Height="640" Width="860"
        MinHeight="540" MinWidth="700"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,20">
            <TextBlock Text="{Binding TitleText}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       FontFamily="Segoe UI Black"/>
            <TextBlock Text="Configure your interval training sequence"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- LEFT COLUMN: Timing Controls -->
        <ScrollViewer Grid.Row="1" Grid.Column="0"
                      VerticalScrollBarVisibility="Auto" Padding="0,0,0,8">
            <StackPanel>

                <!-- Name -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="SEQUENCE NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             MaxLength="60"
                             Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Wait to Start -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="WAIT TO START (seconds)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Style="{StaticResource ModernSlider}"
                                Minimum="{Binding WaitMin}" Maximum="{Binding WaitMax}"
                                Value="{Binding WaitSeconds, Mode=TwoWay}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}" TextAlignment="Center"
                                 Text="{Binding WaitSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>

                <!-- Repeats -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="REPEATS" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Style="{StaticResource ModernSlider}"
                                Minimum="{Binding RepeatsMin}" Maximum="{Binding RepeatsMax}"
                                Value="{Binding Repeats, Mode=TwoWay}"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}" TextAlignment="Center"
                                 Text="{Binding Repeats, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>

                <!-- Work Time -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="WORK TIME (seconds)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Style="{StaticResource ModernSlider}"
                                Minimum="{Binding WorkMin}" Maximum="{Binding WorkMax}"
                                Value="{Binding WorkSeconds, Mode=TwoWay}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}" TextAlignment="Center"
                                 Text="{Binding WorkSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>

                <!-- Rest Time -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="REST TIME (seconds)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Style="{StaticResource ModernSlider}"
                                Minimum="{Binding RestMin}" Maximum="{Binding RestMax}"
                                Value="{Binding RestSeconds, Mode=TwoWay}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}" TextAlignment="Center"
                                 Text="{Binding RestSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>

                <!-- Validation message -->
                <TextBlock Text="{Binding ValidationMessage}"
                           Foreground="#EF4444" FontSize="11" Margin="0,4,0,6"
                           TextWrapping="Wrap"
                           Visibility="{Binding ValidationMessage, Converter={StaticResource BoolToVisibility}}"/>

            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT COLUMN: Call Out -->
        <Grid Grid.Row="1" Grid.Column="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Section header -->
            <TextBlock Grid.Row="0" Text="CALL OUT"
                       Style="{StaticResource FieldLabel}"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="13" Margin="0,0,0,10"/>

            <!-- Mode radio buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton Content="Follow" Margin="0,0,10,0"
                             Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                             IsChecked="{Binding CallOutMode, Converter={StaticResource EnumToBool}, ConverterParameter=Follow}"/>
                <RadioButton Content="Repeat" Margin="0,0,10,0"
                             Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                             IsChecked="{Binding CallOutMode, Converter={StaticResource EnumToBool}, ConverterParameter=Repeat}"/>
                <RadioButton Content="Random" Margin="0,0,10,0"
                             Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                             IsChecked="{Binding CallOutMode, Converter={StaticResource EnumToBool}, ConverterParameter=Random}"/>
                <RadioButton Content="Off"
                             Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                             IsChecked="{Binding CallOutMode, Converter={StaticResource EnumToBool}, ConverterParameter=Off}"/>
            </StackPanel>

            <!-- Voice selector -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AvailableVoices}"
                          SelectedItem="{Binding SelectedVoice, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="🔊 Test"
                        Style="{StaticResource GhostButton}"
                        Padding="10,5" FontSize="11" Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Command="{Binding TestVoiceCommand}"/>
            </Grid>

            <!-- Call Out list -->
            <Border Grid.Row="3"
                    Background="{StaticResource InputBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Margin="0,0,0,8">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding CallOutItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index, StringFormat={}{0}.}"
                                                   Foreground="#A0A0A0" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1"
                                                 Style="{StaticResource ModernTextBox}"
                                                 FontSize="12" Padding="8,5,8,5"
                                                 Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Enter an exercise, or multiple exercises separated by commas"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Off-mode overlay -->
                    <Border Background="#88000000" CornerRadius="6"
                            Visibility="{Binding IsCallOutPanelVisible, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <TextBlock Text="Call Out is OFF — select a mode to configure exercises"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" TextWrapping="Wrap"
                                   Margin="20"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Add / Remove buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        Visibility="{Binding IsCallOutPanelVisible, Converter={StaticResource BoolToVisibility}}">
                <Button Content="+ Add" Style="{StaticResource GhostButton}"
                        Padding="10,4" FontSize="11" Margin="0,0,6,0"
                        Command="{Binding AddCallOutItemCommand}"/>
                <Button Content="− Remove" Style="{StaticResource GhostButton}"
                        Padding="10,4" FontSize="11"
                        Command="{Binding RemoveCallOutItemCommand}"/>
            </StackPanel>
        </Grid>

        <!-- BUTTONS -->
        <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="CANCEL"
                    Style="{StaticResource GhostButton}"
                    Padding="0,12" FontSize="14"
                    Command="{Binding CancelCommand}"/>
            <Button Grid.Column="2" Content="{Binding OkButtonContent}"
                    Style="{StaticResource AccentButton}"
                    Padding="0,12" FontSize="14"
                    Command="{Binding OkCommand}"
                    IsEnabled="{Binding IsOkEnabled}"/>
        </Grid>
    </Grid>
</Window>
