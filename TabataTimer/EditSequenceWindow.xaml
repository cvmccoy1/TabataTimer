<Window x:Class="TabataTimer.EditSequenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sequence Editor"
        Height="640" Width="860"
        MinHeight="540" MinWidth="700"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">

    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>  <!-- Left: timing controls -->
            <ColumnDefinition Width="20"/>  <!-- Gap -->
            <ColumnDefinition Width="3*"/>  <!-- Right: Call Out -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header (spans all) -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Buttons (spans all) -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER (spans both columns) ═══ -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,20">
            <TextBlock x:Name="TitleText" Text="NEW SEQUENCE"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       FontFamily="Segoe UI Black"/>
            <TextBlock Text="Configure your interval training sequence"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ═══ LEFT COLUMN: Timing Controls ═══ -->
        <ScrollViewer Grid.Row="1" Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,0,0,8">
            <StackPanel>

                <!-- Name -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="SEQUENCE NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"
                             MaxLength="60" TextChanged="ValidateForm"/>
                </StackPanel>

                <!-- Wait to Start -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="WAIT TO START (seconds)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="WaitSlider" Grid.Column="0"
                                Style="{StaticResource ModernSlider}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,12,0"
                                ValueChanged="WaitSlider_ValueChanged"/>
                        <TextBox x:Name="WaitBox" Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}" TextAlignment="Center"
                                 PreviewTextInput="NumberOnly_PreviewInput"
                                 TextChanged="WaitBox_TextChanged"/>
                    </Grid>
                </StackPanel>

                <!-- Repeats -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="REPEATS" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="RepeatsSlider" Grid.Column="0"
                                Style="{StaticResource ModernSlider}"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,12,0"
                                ValueChanged="RepeatsSlider_ValueChanged"/>
                        <TextBox x:Name="RepeatsBox" Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}" TextAlignment="Center"
                                 PreviewTextInput="NumberOnly_PreviewInput"
                                 TextChanged="RepeatsBox_TextChanged"/>
                    </Grid>
                </StackPanel>

                <!-- Work Time -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="WORK TIME (seconds)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="WorkSlider" Grid.Column="0"
                                Style="{StaticResource ModernSlider}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,12,0"
                                ValueChanged="WorkSlider_ValueChanged"/>
                        <TextBox x:Name="WorkBox" Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}" TextAlignment="Center"
                                 PreviewTextInput="NumberOnly_PreviewInput"
                                 TextChanged="WorkBox_TextChanged"/>
                    </Grid>
                </StackPanel>

                <!-- Rest Time -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="REST TIME (seconds)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="RestSlider" Grid.Column="0"
                                Style="{StaticResource ModernSlider}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,12,0"
                                ValueChanged="RestSlider_ValueChanged"/>
                        <TextBox x:Name="RestBox" Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}" TextAlignment="Center"
                                 PreviewTextInput="NumberOnly_PreviewInput"
                                 TextChanged="RestBox_TextChanged"/>
                    </Grid>
                </StackPanel>

                <!-- Validation message -->
                <TextBlock x:Name="ValidationMessage" Text=""
                           Foreground="#EF4444" FontSize="11" Margin="0,4,0,6"
                           TextWrapping="Wrap" Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ RIGHT COLUMN: Call Out ═══ -->
        <Grid Grid.Row="1" Grid.Column="2">

            <!-- Call Out: header -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Section header -->
                <RowDefinition Height="Auto"/>  <!-- Mode selector -->
                <RowDefinition Height="Auto"/>  <!-- Voice selector -->
                <RowDefinition Height="*"/>    <!-- List + overlay -->
                <RowDefinition Height="Auto"/>  <!-- Add/Remove buttons -->
            </Grid.RowDefinitions>

            <!-- Section header -->
            <TextBlock Grid.Row="0" Text="CALL OUT"
                       Style="{StaticResource FieldLabel}"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="13" Margin="0,0,0,10"/>

            <!-- Mode radio buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="ModeFollow" Content="Follow" Margin="0,0,10,0"
                             Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                             Checked="CallOutMode_Changed"/>
                <RadioButton x:Name="ModeRepeat" Content="Repeat" Margin="0,0,10,0"
                             Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                             Checked="CallOutMode_Changed"/>
                <RadioButton x:Name="ModeRandom" Content="Random" Margin="0,0,10,0"
                             Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                             Checked="CallOutMode_Changed"/>
                <RadioButton x:Name="ModeOff" Content="Off" IsChecked="True"
                             Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                             Checked="CallOutMode_Changed"/>
            </StackPanel>

            <!-- Voice selector -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="VoiceCombo" Grid.Column="0"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="🔊 Test"
                        Style="{StaticResource GhostButton}"
                        Padding="10,5" FontSize="11" Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Click="TestVoice_Click"/>
            </Grid>

            <!-- Call Out list -->
            <Border Grid.Row="3"
                    Background="{StaticResource InputBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Margin="0,0,0,8">
                <Grid>
                    <!-- Active list -->
                    <ScrollViewer x:Name="CallOutScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="8">
                        <StackPanel x:Name="CallOutPanel"/>
                    </ScrollViewer>

                    <!-- Off-mode overlay -->
                    <Border x:Name="CallOutOffOverlay"
                            Background="#88000000" CornerRadius="6"
                            Visibility="Visible">
                        <TextBlock Text="Call Out is OFF — select a mode to configure exercises"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" TextWrapping="Wrap"
                                   Margin="20"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Add / Remove buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal"
                        x:Name="ListEditButtons" Visibility="Collapsed">
                <Button Content="+ Add" Style="{StaticResource GhostButton}"
                        Padding="10,4" FontSize="11" Margin="0,0,6,0"
                        Click="AddCallOutItem_Click"/>
                <Button Content="− Remove" Style="{StaticResource GhostButton}"
                        Padding="10,4" FontSize="11"
                        Click="RemoveCallOutItem_Click"/>
            </StackPanel>
        </Grid>

        <!-- ═══ BUTTONS (spans both columns) ═══ -->
        <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="CANCEL"
                    Style="{StaticResource GhostButton}"
                    Padding="0,12" FontSize="14"
                    Click="Cancel_Click"/>
            <Button Grid.Column="2" x:Name="OkButton" Content="✓  SAVE SEQUENCE"
                    Style="{StaticResource AccentButton}"
                    Padding="0,12" FontSize="14" IsEnabled="False"
                    Click="Ok_Click"/>
        </Grid>
    </Grid>
</Window>
