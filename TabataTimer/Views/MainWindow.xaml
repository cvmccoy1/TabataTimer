<Window x:Class="TabataTimer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TabataTimer.ViewModels"
        xmlns:conv="clr-namespace:TabataTimer.Converters"
        Title="Tabata Timer" Height="620" Width="900"
        MinHeight="400" MinWidth="720"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- ── Folder Card (implicit by DataType) ── -->
        <DataTemplate DataType="{x:Type vm:FolderViewModel}">
            <Border x:Name="FolderBorder"
                    Background="#1A1F2E"
                    BorderBrush="#2D3550" BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,8"
                    Padding="20,14,20,14"
                    AllowDrop="True"
                    PreviewMouseLeftButtonDown="Card_MouseDown"
                    MouseMove="Card_MouseMove"
                    MouseLeftButtonUp="Card_MouseUp"
                    DragEnter="FolderCard_DragEnter"
                    DragLeave="FolderCard_DragLeave"
                    DragOver="FolderCard_DragOver"
                    Drop="FolderCard_Drop">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <TextBlock Grid.Column="0" Text="📁"
                               FontSize="30" VerticalAlignment="Center"
                               Margin="0,0,16,0"/>

                    <!-- Name + count -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#F5F5F5"
                                   FontFamily="Segoe UI Semibold"/>
                        <TextBlock Text="{Binding ItemCountDisplay}"
                                   FontSize="12" Foreground="#808080"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Move Up/Down -->
                    <StackPanel Grid.Column="2" Orientation="Vertical"
                                VerticalAlignment="Center" Margin="8,0">
                        <Button Content="▲"
                                Background="#3A3A3A" Foreground="#A0A0A0"
                                FontSize="11" Padding="8,3" BorderThickness="0" Cursor="Hand"
                                Margin="0,0,0,2"
                                Click="MoveFolderUp_Click"/>
                        <Button Content="▼"
                                Background="#3A3A3A" Foreground="#A0A0A0"
                                FontSize="11" Padding="8,3" BorderThickness="0" Cursor="Hand"
                                Click="MoveFolderDown_Click"/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="📂  OPEN"
                                Background="#6366F1" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8" BorderThickness="0" Cursor="Hand"
                                Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="✏  EDIT"
                                Background="#3B82F6" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8" BorderThickness="0" Cursor="Hand"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.RenameFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="⎘  COPY"
                                Background="#0EA5E9" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8" BorderThickness="0" Cursor="Hand"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.CopyFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="🗑  DELETE"
                                Background="#EF4444" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8" BorderThickness="0" Cursor="Hand"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ── Sequence Card (implicit by DataType) ── -->
        <DataTemplate DataType="{x:Type vm:TabataSequenceViewModel}">
            <Border Background="#222222"
                    BorderBrush="#333333" BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,8"
                    Padding="20,16,20,16"
                    PreviewMouseLeftButtonDown="Card_MouseDown"
                    MouseMove="Card_MouseMove"
                    MouseLeftButtonUp="Card_MouseUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: name + stats -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#F5F5F5"
                                   FontFamily="Segoe UI Semibold"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel>
                                <TextBlock Text="WAIT" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding WaitDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="#A0A0A0" FontFamily="Consolas"/>
                            </StackPanel>
                            <Border Width="1" Background="#444444" Margin="16,0"/>
                            <StackPanel>
                                <TextBlock Text="REPEAT" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding RepeatsDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="#3B82F6" FontFamily="Consolas"/>
                            </StackPanel>
                            <Border Width="1" Background="#444444" Margin="16,0"/>
                            <StackPanel>
                                <TextBlock Text="WORK" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding WorkDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="#22C55E" FontFamily="Consolas"/>
                            </StackPanel>
                            <Border Width="1" Background="#444444" Margin="16,0"/>
                            <StackPanel>
                                <TextBlock Text="REST" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding RestDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="#FF4500" FontFamily="Consolas"/>
                            </StackPanel>
                            <Border Width="1" Background="#444444" Margin="16,0"/>
                            <StackPanel>
                                <TextBlock Text="TOTAL" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding TotalDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="#E2E8F0" FontFamily="Consolas"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Move Up/Down -->
                    <StackPanel Grid.Column="1" Orientation="Vertical"
                                VerticalAlignment="Center" Margin="8,0">
                        <Button Content="▲"
                                Background="#3A3A3A" Foreground="#A0A0A0"
                                FontSize="11" Padding="8,3" BorderThickness="0" Cursor="Hand"
                                Margin="0,0,0,2"
                                Click="MoveUp_Click"/>
                        <Button Content="▼"
                                Background="#3A3A3A" Foreground="#A0A0A0"
                                FontSize="11" Padding="8,3" BorderThickness="0" Cursor="Hand"
                                Click="MoveDown_Click"/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="▶  START"
                                Background="#22C55E" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="18,10" BorderThickness="0" Cursor="Hand"
                                Command="{Binding DataContext.StartSequenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="✏  EDIT"
                                Background="#3B82F6" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8" BorderThickness="0" Cursor="Hand"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.EditSequenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="⎘  COPY"
                                Background="#0EA5E9" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8" BorderThickness="0" Cursor="Hand"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.DuplicateSequenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="🗑  DELETE"
                                Background="#EF4444" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8" BorderThickness="0" Cursor="Hand"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.DeleteSequenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back button -->
                <Button Grid.Column="0"
                        Content="◀  BACK"
                        Style="{StaticResource GhostButton}"
                        FontSize="13" Padding="14,10"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsAtRoot, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                        Command="{Binding BackCommand}"/>

                <!-- Logo -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⏱" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="TABATA TIMER"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Segoe UI Black"/>
                        <TextBlock Text="Interval Training Sequences"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- New Folder + New Sequence -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📁  NEW FOLDER"
                            Style="{StaticResource CyanButton}"
                            FontSize="13" Padding="16,10"
                            Margin="0,0,8,0"
                            Command="{Binding NewFolderCommand}"/>
                    <Button Content="+ NEW SEQUENCE"
                            Style="{StaticResource AccentButton}"
                            FontSize="13" Padding="20,10"
                            Command="{Binding NewSequenceCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Breadcrumb bar ── -->
        <Border Grid.Row="1" Background="#111111"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,7">
            <ItemsControl ItemsSource="{Binding Breadcrumbs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BreadcrumbItem}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text=" ›  "
                                       Foreground="#555555" FontSize="15"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsFirst, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                            <Button Content="{Binding Name}"
                                    Background="Transparent"
                                    Foreground="#A0A0A0"
                                    FontSize="13"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="2,2"
                                    Command="{Binding NavigateCommand}"
                                    AllowDrop="True"
                                    DragOver="Breadcrumb_DragOver"
                                    Drop="Breadcrumb_Drop">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#A0A0A0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#F5F5F5"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ── Item list ── -->
        <Grid Grid.Row="2" x:Name="ItemsGrid"
              AllowDrop="True"
              DragOver="ItemsGrid_DragOver"
              DragLeave="ItemsGrid_DragLeave"
              Drop="ItemsGrid_Drop">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <ItemsControl x:Name="ItemsList"
                              ItemsSource="{Binding CurrentItems}"
                              Background="Transparent">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Margin="0,8,0,8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
            <!-- Reorder insertion indicator — overlaid, not hit-testable -->
            <Border x:Name="InsertionIndicator"
                    Height="3" Background="#FF4500" CornerRadius="1.5"
                    IsHitTestVisible="False" Visibility="Collapsed"
                    VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Margin="16,0,16,0"/>
        </Grid>

        <!-- ── Empty state ── -->
        <StackPanel Grid.Row="2"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🏋️" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="Nothing here yet"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Create a sequence or a folder to get started"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,8,0,24"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="📁  NEW FOLDER"
                        Style="{StaticResource GhostButton}"
                        Padding="20,12" FontSize="14"
                        Margin="0,0,12,0"
                        Command="{Binding NewFolderCommand}"/>
                <Button Content="+ NEW SEQUENCE"
                        Style="{StaticResource AccentButton}"
                        Padding="24,12" FontSize="14"
                        Command="{Binding NewSequenceCommand}"/>
            </StackPanel>
        </StackPanel>

        <!-- ── Footer ── -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,10">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
