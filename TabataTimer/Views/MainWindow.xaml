<Window x:Class="TabataTimer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TabataTimer.ViewModels"
        xmlns:conv="clr-namespace:TabataTimer.Converters"
        Title="Tabata Timer" Height="620" Width="860"
        MinHeight="400" MinWidth="700"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Sequence Card DataTemplate -->
        <DataTemplate x:Key="SequenceCardTemplate" DataType="{x:Type vm:TabataSequenceViewModel}">
            <Border Background="#222222"
                    BorderBrush="#333333" BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,8"
                    Padding="20,16,20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: name + stats -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#F5F5F5"
                                   FontFamily="Segoe UI Semibold"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="WAIT" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding WaitDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="#A0A0A0" FontFamily="Consolas"/>
                            </StackPanel>
                            <Border Width="1" Background="#444444" Margin="16,0,16,0"/>
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="REPEAT" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding RepeatsDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="#3B82F6" FontFamily="Consolas"/>
                            </StackPanel>
                            <Border Width="1" Background="#444444" Margin="16,0,16,0"/>
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="WORK" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding WorkDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="#22C55E" FontFamily="Consolas"/>
                            </StackPanel>
                            <Border Width="1" Background="#444444" Margin="16,0,16,0"/>
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="REST" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#A0A0A0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding RestDisplay}" FontSize="16" FontWeight="Bold"
                                           Foreground="#FF4500" FontFamily="Consolas"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Move Up/Down buttons -->
                    <StackPanel Grid.Column="1" Orientation="Vertical"
                               VerticalAlignment="Center" Margin="8,0,8,0">
                        <Button Content="▲"
                                Background="#3A3A3A" Foreground="#A0A0A0"
                                FontSize="11" Padding="8,3,8,3"
                                BorderThickness="0" Cursor="Hand"
                                Margin="0,0,0,2"
                                Click="MoveUp_Click"/>
                        <Button Content="▼"
                                Background="#3A3A3A" Foreground="#A0A0A0"
                                FontSize="11" Padding="8,3,8,3"
                                BorderThickness="0" Cursor="Hand"
                                Click="MoveDown_Click"/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="▶  START"
                                Background="#22C55E" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="18,10,18,10" BorderThickness="0" Cursor="Hand"
                                Command="{Binding DataContext.StartSequenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="✏  EDIT"
                                Background="#3B82F6" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8,14,8" BorderThickness="0" Cursor="Hand"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.EditSequenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="⎘  COPY"
                                Background="#0EA5E9" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8,14,8" BorderThickness="0" Cursor="Hand"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.DuplicateSequenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                        <Button Content="🗑  DELETE"
                                Background="#EF4444" Foreground="White"
                                FontSize="13" FontFamily="Segoe UI Semibold"
                                Padding="14,8,14,8" BorderThickness="0" Cursor="Hand"
                                Margin="8,0,0,0"
                                Command="{Binding DataContext.DeleteSequenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⏱" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="TABATA TIMER"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Segoe UI Black"/>
                        <TextBlock Text="Interval Training Sequences"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="+ NEW SEQUENCE"
                        Style="{StaticResource AccentButton}"
                        FontSize="13" Padding="20,10"
                        Command="{Binding NewSequenceCommand}"/>
            </Grid>
        </Border>

        <!-- Sequence List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <ItemsControl ItemsSource="{Binding Sequences}"
                         ItemTemplate="{StaticResource SequenceCardTemplate}"
                         Background="Transparent">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Margin="0,8,0,8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="1"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                   VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🏋️" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="No sequences yet"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Click + NEW SEQUENCE to create your first Tabata interval"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,8,0,24"/>
            <Button Content="+ CREATE FIRST SEQUENCE" Style="{StaticResource AccentButton}"
                    HorizontalAlignment="Center" Padding="24,12" FontSize="14"
                    Command="{Binding NewSequenceCommand}"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,10">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
