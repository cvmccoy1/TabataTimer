<Window x:Class="TabataTimer.TimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TabataTimer.ViewModels"
        xmlns:conv="clr-namespace:TabataTimer.Converters"
        Title="Tabata Timer — Running" Height="660" Width="520"
        ResizeMode="CanMinimize"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sequence Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center">
            <TextBlock Text="{Binding SequenceName}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Phase Label (WAIT / WORK / REST / READY / DONE) -->
        <Border Grid.Row="1" HorizontalAlignment="Center"
                Background="{StaticResource CardBrush}"
                CornerRadius="20" Padding="24,8" Margin="0,0,0,12">
            <TextBlock Text="{Binding PhaseLabel}"
                       FontSize="22" FontWeight="Bold"
                       FontFamily="Segoe UI Black"
                       Foreground="{Binding PhaseLabelForeground}"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Call Out Exercise Name -->
        <Grid Grid.Row="2" Height="70" Margin="0,0,0,12">
            <Border Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource GreenBrush}" BorderThickness="2"
                    CornerRadius="12" Padding="20,10"
                    Visibility="{Binding ExerciseVisible, Converter={StaticResource BoolToVisibility}}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <TextBlock Text="{Binding ExerciseLabel}"
                           FontSize="28" FontWeight="Bold"
                           FontFamily="Segoe UI Black"
                           Foreground="{StaticResource GreenBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Main Countdown Timer -->
        <Border Grid.Row="3" HorizontalAlignment="Center"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="16" Padding="40,20" Margin="0,0,0,20">
            <TextBlock Text="{Binding CountdownDisplay}"
                       FontSize="96" FontWeight="Bold"
                       FontFamily="Consolas"
                       Foreground="{Binding CountdownForeground}"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Total Timer + Round Row -->
        <Grid Grid.Row="4" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total elapsed time -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="16,12" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL TIME" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding TotalDisplay}"
                               FontSize="32" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="{StaticResource BlueBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Round counter -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="16,12" Margin="8,0,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ROUND" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding RoundDisplay}"
                               FontSize="32" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="{StaticResource GreenBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Divider -->
        <Border Grid.Row="5" Height="1"
                Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

        <!-- Volume + Warning Beep -->
        <Grid Grid.Row="6" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Volume -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="🔊  VOLUME" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <Slider Style="{StaticResource ModernSlider}"
                        Minimum="0" Maximum="1" SmallChange="0.05"
                        VerticalAlignment="Center"
                        Value="{Binding Volume, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Warning Beep -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="⚠  WARNING BEEP" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <CheckBox Content="3-second countdown"
                          Style="{StaticResource ModernCheckBox}"
                          IsChecked="{Binding WarningBeepEnabled, Mode=TwoWay}"/>
            </StackPanel>
        </Grid>

        <!-- Divider -->
        <Border Grid.Row="7" Height="1"
                Background="{StaticResource BorderBrush}"/>

        <!-- Spacer -->
        <Grid Grid.Row="8"/>

        <!-- Control Buttons -->
        <Grid Grid.Row="9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="▶  START"
                    Style="{StaticResource GreenButton}"
                    Padding="0,14" FontSize="14"
                    Command="{Binding StartCommand}"
                    IsEnabled="{Binding StartEnabled}"/>

            <Button Grid.Column="2" Content="{Binding PauseButtonContent}"
                    Style="{StaticResource YellowButton}"
                    Padding="0,14" FontSize="14"
                    Command="{Binding PauseCommand}"
                    IsEnabled="{Binding PauseEnabled}"/>

            <Button Grid.Column="4" Content="⏹  STOP"
                    Style="{StaticResource RedButton}"
                    Padding="0,14" FontSize="14"
                    Command="{Binding StopCommand}"
                    IsEnabled="{Binding StopEnabled}"/>

            <Button Grid.Column="6" Content="✕  EXIT"
                    Style="{StaticResource GhostButton}"
                    Padding="0,14" FontSize="14"
                    Command="{Binding ExitCommand}"/>
        </Grid>
    </Grid>
</Window>
